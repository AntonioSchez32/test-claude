[req]
default_bits       = 4096
distinguished_name = req_distinguished_name
req_extensions     = req_ext
x509_extensions    = v3_req
prompt             = no

[req_distinguished_name]
C  = ES
ST = Madrid
L  = Madrid
O  = Instituto Nacional de Estadística
OU = Delegación Provincial del INE de Huelva
CN = ine.es

[req_ext]
subjectAltName = @alt_names

[v3_req]
subjectAltName = @alt_names

[alt_names]
# Dominios
DNS.1 = ine.es
DNS.2 = localhost

# IPs específicas
IP.1 = 127.0.0.1
IP.2 = 10.58.21.32
IP.3 = 10.58.21.17
IP.4 = 10.58.21.100
IP.5 = 10.59.178.21
